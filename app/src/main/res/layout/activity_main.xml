<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?android:attr/windowBackground">

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quản Lý Tài Chính"
        android:layout_marginTop="40dp"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/primary_green" />

    <TextView
        android:id="@+id/txtWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chào, Đạt!"
        android:layout_marginTop="20dp"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_rounded_white"
        android:padding="20dp"
        android:layout_marginTop="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tổng số dư"
            android:textStyle="bold"
            android:textColor="#808080"/>

        <TextView
            android:id="@+id/txtBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 VND"
            android:textSize="24sp"
            android:textColor="#000000"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tiết kiệm" android:textColor="#808080" android:textStyle="bold" />
                <TextView android:id="@+id/txtSavings" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 VND" android:textColor="#000000" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nợ" android:textColor="#808080" android:textStyle="bold" />
                <TextView android:id="@+id/txtDebt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 VND" android:textColor="#000000" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chức năng"
        android:layout_marginTop="20dp"
        android:textColor="#000000"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_rounded_white"
        android:layout_marginTop="20dp"
        android:padding="10dp"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <LinearLayout
                android:id="@+id/btnDeposit"
                style="@style/MomoButtonStyle"
                android:layout_weight="1">
                <ImageView android:src="@drawable/ic_deposit" style="@style/MomoIconStyle" />
                <TextView android:text="Gửi tiền" style="@style/MomoTextStyle" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnWithdraw"
                style="@style/MomoButtonStyle"
                android:layout_weight="1">
                <ImageView android:src="@drawable/ic_transfer" style="@style/MomoIconStyle" />
                <TextView android:text="Rút tiền" style="@style/MomoTextStyle" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnSavings"
                style="@style/MomoButtonStyle"
                android:layout_weight="1">
                <ImageView android:src="@drawable/ic_saving" style="@style/MomoIconStyle" />
                <TextView android:text="Tiết kiệm" style="@style/MomoTextStyle" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="15dp"
            android:weightSum="3">

            <LinearLayout
                android:id="@+id/btnHistory"
                style="@style/MomoButtonStyle"
                android:layout_weight="1">
                <ImageView android:src="@drawable/ic_history" style="@style/MomoIconStyle" />
                <TextView android:text="Lịch sử" style="@style/MomoTextStyle" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnStats"
                style="@style/MomoButtonStyle"
                android:layout_weight="1">
                <ImageView android:src="@drawable/ic_chart" style="@style/MomoIconStyle" />
                <TextView android:text="Thống kê" style="@style/MomoTextStyle" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnExit"
                style="@style/MomoButtonStyle"
                android:layout_weight="1">
                <ImageView android:src="@drawable/ic_exit" style="@style/MomoIconStyle" />
                <TextView android:text="Thoát" style="@style/MomoTextStyle" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>